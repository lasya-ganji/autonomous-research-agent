OPENAI_API_KEY=your_openai_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=your_project_name_here

# Optional: comma-separated list of domains to block at the Tavily API level.
# Setting this REPLACES the built-in defaults entirely, so include all domains you want blocked.
# Defaults (used when this variable is not set):
#   youtu.be, quora.com, instagram.com, linkedin.com, facebook.com, pinterest.com,
#   twitter.com, x.com, tiktok.com, snapchat.com, discord.com
#
# To extend the defaults, copy them here and append your extras:
# SEARCH_EXCLUDE_DOMAINS=youtu.be,quora.com,instagram.com,linkedin.com,facebook.com,pinterest.com,twitter.com,x.com,tiktok.com,snapchat.com,discord.com